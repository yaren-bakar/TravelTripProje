@model TravelTripProje.Models.Siniflar.Yorumlar
@{
    ViewBag.Title = "YorumGetir";
    Layout = "~/Views/Shared/_AdmimLayout.cshtml";
}

<h2>Yorum Güncelle</h2>
<br />
@using (Html.BeginForm("YorumGuncelle", "Admin", FormMethod.Post))
{
    <div>
        @Html.LabelFor(x => x.ID)
        @Html.TextBoxFor(x => x.ID, new { @class = "form-control", @readonly = "readonly" })
    </div>
    <br />
    <div>
        @Html.LabelFor(x => x.KullaniciAdi)
        @Html.TextBoxFor(x => x.KullaniciAdi, new { @class = "form-control" })
    </div>
    <br />

    <div>
        @Html.LabelFor(x => x.Mail)
        @Html.TextBoxFor(x => x.Mail, new { @class = "form-control" })
    </div>
    <br />
    <div>
        @Html.LabelFor(x => x.Yorum)
        @Html.TextAreaFor(x => x.Yorum,9,1, new { @class = "form-control" })
    </div>
    <br />
    <div>
        @Html.LabelFor(x => x.Blogid)
        @Html.TextBoxFor(x => x.Blogid, new { @class = "form-control" })
    </div>
    <br />

 <button class="btn btn-success">GÜNCELLE</button>

}

