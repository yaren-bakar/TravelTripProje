@{
    Layout = null;
}
<div class="content-form">
    <h3>Bir Yorum Yazınız</h3>
    <form method="post" action="/Blog/YorumYap">
        <input type="hidden" placeholder="ID" name="Blogid" value="@ViewBag.deger" required />
        <input type="text" placeholder="Kullanıcı Adı: " name="KullaniciAdi" required />
        <input type="text" placeholder="Mail Adresi: " name="Mail" required />
        <textarea placeholder="Mesaj" name="Yorum"></textarea>
        <input type="submit" value="GÖNDER" />
    </form>
</div>