@using TravelTripProje.Models.Siniflar
@model List<Blog>
<div class="con-bot">
    @foreach (var x in Model)
    {
        <div  class="left">
            <div class="bot-left">
              <img src="@x.BlogImage" style="width: 300px; height: 150px;" alt="" />
            </div>

            <div class="left-text">
                <h4>@x.Baslik</h4>
                <span class="doller">@x.Tarih.ToString("dd.MM.yyyy")</span>

                <p>
                    @if (x.Açiklama != null && x.Açiklama.Length > 120)
                    {
                        @x.Açiklama.Substring(0,120)<span>...</span>
                    }
                    else
                    {
                        @x.Açiklama
                    }
                </p>

                <p><a href="/Blog/BlogDetay/@x.ID"><span class="read">Devamı...</span></a></p>
            </div>
        </div>
    }
</div>